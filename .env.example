# Backend
PORT=8787
COINGECKO_API_BASE=https://api.coingecko.com/api/v3
ALLOWED_ORIGIN=*
BACKUP_DIR=/data/backups

# Frontend — set as GitHub repo variable for CI (Pages + Docker frontend image)
# VITE_API_BASE_URL=https://api-nimconnect.maestroi.cc
# Local dev: leave empty (Vite proxies /api to localhost:8787)
# VITE_NIMPAY_MINIAPP_DOMAIN=nimconnect.maestroi.cc
# Handles default to the NimFeed catalog address; override only if needed:
# VITE_REGISTRY_ADDRESS=NQ19 LLHP G0ML 37RM 5JJD RME1 GLFY 75PQ 402Y
# Backend: REGISTRY_ADDRESS=off disables handle routes
