{
  "name": "nimconnect",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:https": "VITE_HTTPS=true vite",
    "dev:backend": "docker compose up --build",
    "build": "vue-tsc -b && vite build",
    "build:pages": "GITHUB_PAGES=true npm run build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:profile-client": "npm run test -w @nimconnect/profile-client"
  },
  "dependencies": {
    "@fontsource/mulish": "^5.2.5",
    "@nimconnect/profile-client": "*",
    "@nimiq/hub-api": "^1.14.0",
    "@nimiq/identicons": "^1.6.2",
    "@nimiq/mini-app-sdk": "^0.1.0",
    "@nimiq/utils": "^0.12.4",
    "@noble/ciphers": "^1.3.0",
    "@noble/hashes": "^1.8.0",
    "dexie": "^4.0.11",
    "pinia": "^3.0.1",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.7.0",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^20.10.6",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8",
    "vue-tsc": "^2.2.8"
  },
  "license": "MIT"
}
