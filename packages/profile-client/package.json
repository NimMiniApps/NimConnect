{
  "name": "@nimconnect/profile-client",
  "version": "0.2.0",
  "description": "Read and claim @handles and public profiles on the shared NimFeed/NimConnect identity registry — works with any Nimiq mini app, on-chain or via NimConnect's API.",
  "keywords": ["nimiq", "nimconnect", "nimfeed", "handle", "profile", "identity"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "~5.7.2",
    "vitest": "^3.0.8"
  },
  "license": "MIT"
}
